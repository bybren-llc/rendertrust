# RenderTrust Production Environment Variables
#
# Copy this file to .env and fill in all values marked CHANGE_ME.
# This template maps to core/config.py AppSettings fields.
#
# Usage:
#   cp env.template .env
#   # Edit .env with production values
#   # Or configure directly in Coolify UI > Environment Variables
#
# SECURITY: Never commit .env files to version control.
# SECURITY: Generate secrets with: openssl rand -hex 32

# ── Application ────────────────────────────────────────────────────

# Application name (used in logs and health endpoint)
APP_NAME=rendertrust

# Environment: development | staging | production
# IMPORTANT: Setting this to "production" enables strict secret validation,
# disables Swagger docs, and enables HSTS headers.
APP_ENV=production

# Debug mode: true | false
# WARNING: Never enable in production -- exposes stack traces and enables
# Swagger/ReDoc documentation endpoints.
APP_DEBUG=false

# Bind address and port for uvicorn
APP_HOST=0.0.0.0
APP_PORT=8000

# Application secret key (used for general-purpose signing)
# REQUIRED: Generate with: openssl rand -hex 32
SECRET_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32

# ── Database (PostgreSQL 16) ───────────────────────────────────────

# Connection string for the app service.
# Points to the 'db' service in docker-compose.coolify.yml by default.
# Override if using an external managed database (e.g., Hetzner Managed DB).
DATABASE_URL=postgresql+asyncpg://rendertrust:CHANGE_ME_POSTGRES_PASSWORD@db:5432/rendertrust

# Password for the PostgreSQL container (must match DATABASE_URL above)
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD

# Connection pool tuning (defaults are suitable for a 4GB VPS)
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ── Redis ──────────────────────────────────────────────────────────

# Connection string for the Redis service.
# Points to the 'redis' service in docker-compose.coolify.yml by default.
REDIS_URL=redis://redis:6379/0

# ── Authentication (JWT) ───────────────────────────────────────────

# JWT signing secret (independent of SECRET_KEY for defense-in-depth)
# REQUIRED: Generate with: openssl rand -hex 32
JWT_SECRET_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32

# JWT algorithm (HS256 is the default; change only if you know what you're doing)
JWT_ALGORITHM=HS256

# Access token lifetime in minutes (default: 30)
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# Refresh token lifetime in days (default: 7)
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Stripe (Payments) ─────────────────────────────────────────────

# Stripe API secret key (starts with sk_live_ or sk_test_)
STRIPE_SECRET_KEY=

# Stripe webhook signing secret (starts with whsec_)
# Used to verify webhook payloads from Stripe.
STRIPE_WEBHOOK_SECRET=

# Stripe publishable key (starts with pk_live_ or pk_test_)
# Exposed to frontend for Stripe.js initialization.
STRIPE_PUBLISHABLE_KEY=

# ── Monitoring ─────────────────────────────────────────────────────

# Sentry DSN for error tracking (leave empty to disable)
SENTRY_DSN=

# PostHog API key for product analytics (leave empty to disable)
POSTHOG_API_KEY=

# ── x402 Payment Protocol (PoC -- disabled by default) ────────────

# Enable the x402 HTTP payment middleware (experimental)
X402_ENABLED=false

# EVM wallet address to receive x402 payments
X402_PAY_TO=

# x402 facilitator URL
X402_FACILITATOR_URL=https://x402.org/facilitator

# EVM network identifier (default: Base Sepolia testnet)
X402_NETWORK=eip155:84532

# Price per compute request via x402
X402_COMPUTE_PRICE=$0.01

# ── CORS ───────────────────────────────────────────────────────────

# Comma-separated list of allowed origins
# Update with your actual frontend domain(s) in production.
CORS_ORIGINS=["https://app.rendertrust.com"]

# Allowed HTTP methods
CORS_ALLOW_METHODS=["GET","POST","PUT","DELETE","OPTIONS"]

# Allowed request headers
CORS_ALLOW_HEADERS=["Authorization","Content-Type","X-Request-ID"]

# ── Object Storage (S3-compatible: AWS S3, Cloudflare R2, MinIO) ──

# S3-compatible endpoint URL
# Examples:
#   AWS S3:        https://s3.us-east-1.amazonaws.com
#   Cloudflare R2: https://<account-id>.r2.cloudflarestorage.com
#   MinIO:         http://minio:9000
S3_ENDPOINT=

# S3 access key ID
S3_ACCESS_KEY=

# S3 secret access key
S3_SECRET_KEY=

# S3 bucket name for render artifacts and storage
S3_BUCKET=rendertrust-storage

# S3 region (required for AWS S3, optional for R2/MinIO)
S3_REGION=auto
