{
  "dashboard": {
    "id": null,
    "uid": "rendertrust-fleet-health",
    "title": "RenderTrust - Fleet Health",
    "description": "Edge fleet node status, WebSocket connections, and fleet load overview for the RenderTrust platform.",
    "tags": ["rendertrust", "fleet"],
    "timezone": "browser",
    "editable": true,
    "schemaVersion": 39,
    "graphTooltip": 1,
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "refresh": "10s",
    "templating": {
      "list": []
    },
    "annotations": {
      "list": []
    },
    "panels": [
      {
        "title": "Total Nodes",
        "type": "stat",
        "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "color": { "mode": "thresholds" },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "blue", "value": null }
              ]
            }
          },
          "overrides": []
        },
        "options": {
          "reduceOptions": { "calcs": ["lastNotNull"] },
          "colorMode": "background",
          "graphMode": "none",
          "textMode": "auto"
        },
        "targets": [
          {
            "expr": "sum(fleet_nodes_total)",
            "legendFormat": "Total",
            "refId": "A"
          }
        ]
      },
      {
        "title": "Healthy Nodes",
        "type": "stat",
        "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "color": { "mode": "thresholds" },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "green", "value": null }
              ]
            }
          },
          "overrides": []
        },
        "options": {
          "reduceOptions": { "calcs": ["lastNotNull"] },
          "colorMode": "background",
          "graphMode": "none",
          "textMode": "auto"
        },
        "targets": [
          {
            "expr": "fleet_nodes_total{status=\"healthy\"}",
            "legendFormat": "Healthy",
            "refId": "A"
          }
        ]
      },
      {
        "title": "Unhealthy Nodes",
        "type": "stat",
        "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 },
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "color": { "mode": "thresholds" },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "green", "value": null },
                { "color": "yellow", "value": 1 },
                { "color": "red", "value": 5 }
              ]
            }
          },
          "overrides": []
        },
        "options": {
          "reduceOptions": { "calcs": ["lastNotNull"] },
          "colorMode": "background",
          "graphMode": "none",
          "textMode": "auto"
        },
        "targets": [
          {
            "expr": "fleet_nodes_total{status=\"unhealthy\"}",
            "legendFormat": "Unhealthy",
            "refId": "A"
          }
        ]
      },
      {
        "title": "Offline Nodes",
        "type": "stat",
        "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "color": { "mode": "thresholds" },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "green", "value": null },
                { "color": "orange", "value": 1 },
                { "color": "red", "value": 3 }
              ]
            }
          },
          "overrides": []
        },
        "options": {
          "reduceOptions": { "calcs": ["lastNotNull"] },
          "colorMode": "background",
          "graphMode": "none",
          "textMode": "auto"
        },
        "targets": [
          {
            "expr": "fleet_nodes_total{status=\"offline\"}",
            "legendFormat": "Offline",
            "refId": "A"
          }
        ]
      },
      {
        "title": "Node Status Over Time",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 24, "x": 0, "y": 6 },
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "custom": {
              "fillOpacity": 20,
              "stacking": { "mode": "normal" }
            }
          },
          "overrides": [
            {
              "matcher": { "id": "byName", "options": "healthy" },
              "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
            },
            {
              "matcher": { "id": "byName", "options": "unhealthy" },
              "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }]
            },
            {
              "matcher": { "id": "byName", "options": "offline" },
              "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
            }
          ]
        },
        "options": {
          "legend": { "displayMode": "list", "placement": "bottom" },
          "tooltip": { "mode": "multi" }
        },
        "targets": [
          {
            "expr": "fleet_nodes_total",
            "legendFormat": "{{status}}",
            "refId": "A"
          }
        ]
      },
      {
        "title": "Active WebSocket Connections",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 24, "x": 0, "y": 14 },
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "color": { "fixedColor": "blue", "mode": "fixed" },
            "custom": {
              "fillOpacity": 15
            },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "green", "value": null },
                { "color": "yellow", "value": 50 },
                { "color": "red", "value": 100 }
              ]
            }
          },
          "overrides": []
        },
        "options": {
          "legend": { "displayMode": "list", "placement": "bottom" },
          "tooltip": { "mode": "multi" }
        },
        "targets": [
          {
            "expr": "active_websocket_connections",
            "legendFormat": "Active Connections",
            "refId": "A"
          }
        ]
      },
      {
        "title": "Fleet Load",
        "description": "Ratio of healthy nodes to total registered nodes. A low gauge indicates many nodes are unhealthy or offline.",
        "type": "gauge",
        "gridPos": { "h": 8, "w": 24, "x": 0, "y": 22 },
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "min": 0,
            "max": 1,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "red", "value": null },
                { "color": "yellow", "value": 0.5 },
                { "color": "green", "value": 0.8 }
              ]
            }
          },
          "overrides": []
        },
        "options": {
          "reduceOptions": { "calcs": ["lastNotNull"] },
          "showThresholdLabels": false,
          "showThresholdMarkers": true
        },
        "targets": [
          {
            "expr": "fleet_nodes_total{status=\"healthy\"} / sum(fleet_nodes_total)",
            "legendFormat": "Fleet Health",
            "refId": "A"
          }
        ]
      }
    ]
  }
}
